#!/usr/bin/env bash
# pre-commit — staged 파일만 arch 감사 (기존 위반 baseline 유지, 새 변경만 차단)
# Bypass (긴급용): git commit --no-verify
set -e
cd "$(git rev-parse --show-toplevel)"

STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(svelte|ts|tsx)$' || true)
if [ -z "$STAGED" ]; then
	echo "✓ pre-commit: 검사할 staged 파일 없음"
	exit 0
fi

echo "→ arch:audit (staged $(echo "$STAGED" | wc -l | tr -d ' ')개)"
echo "$STAGED" | xargs bun .svelte-arch/arch.mjs audit --files

echo "✓ pre-commit OK"
